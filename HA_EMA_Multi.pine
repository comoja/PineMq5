//@version=6
strategy("HA_EMA Multi (Gold & Silver)", overlay=true, initial_capital=450,
         default_qty_type=strategy.percent_of_equity, default_qty_value=10,
         commission_type=strategy.commission.percent, commission_value=0.04)

//+------------------------------------------------------------------+
//|                                             HA_EMA_Multi.pine    |
//|               Estrategia Unificada Heikin-Ashi + EMA             |
//|                    para ORO (XAU) y PLATA (XAG)                  |
//|          Con Autodetección de Activo, MTF y Break-Even           |
//+------------------------------------------------------------------+

// ════════════════════════════════════════════════════════════════════
// 1. INPUTS DE PERFIL Y AUTODETECCIÓN
// ════════════════════════════════════════════════════════════════════
gpProf       = "--- PERFIL DE CONFIGURACIÓN ---"
assetProfile = input.string("Auto", "Perfil de Activo", options=["Auto", "Oro (XAUUSD)", "Plata (XAGUSD)", "Bitcoin (BTCUSD)", "Nasdaq (NAS100)", "Manual"], group=gpProf,
                 tooltip="Auto: detecta el símbolo actual para aplicar los parámetros óptimos de Oro, Plata, Bitcoin o Nasdaq. Manual: usa los parámetros de abajo.")

// ════════════════════════════════════════════════════════════════════
// 2. INPUTS DE GESTIÓN DE RIESGO
// ════════════════════════════════════════════════════════════════════
gpRisk       = "--- GESTIÓN DE RIESGO ---"
riskPerc     = input.float(1.0, "Riesgo por operación (%)", minval=0.1, maxval=10.0, group=gpRisk,
                 tooltip="Porcentaje de la equidad a arriesgar basado en la distancia del SL inicial")
useTP        = input.bool(true, "Usar Take Profit Fijo", group=gpRisk)
rrRatioIn   = input.float(3.0, "Relación Riesgo/Recompensa (R:R)", minval=0.5, step=0.1, group=gpRisk,
                 tooltip="Oro sugerido: 3.0. Plata sugerido: 2.5.")
useBEIn     = input.bool(true, "Mover a Break-Even (Precio Entrada)", group=gpRisk,
                 tooltip="ACTIVADO: protege el capital moviendo el SL a precio de entrada cuando el precio avanza a tu favor.")
beRatioIn   = input.float(1.0, "Multiplicador R:R para Break-Even", minval=0.3, step=0.1, group=gpRisk,
                 tooltip="1.0 = mueve a Break-Even al alcanzar beneficio 1:1 R:R (seguridad absoluta).")
useTPChaseIn = input.bool(false, "Usar Persecución de TP (TP Chasing)", group=gpRisk,
                 tooltip="ACTIVADO: el TP se aleja del precio si este se acerca a la distancia especificada.")
 
chase = 3.0
tpChasePtsIn = input.float(chase, "Distancia de Persecución TP (Pts)", minval=0.1, step=1.0, group=gpRisk,
                 tooltip="Distancia en puntos/ticks desde el precio hasta el TP para activar la persecución.")
tpChaseOffsetIn = input.float(chase, "Avance del TP (Pts)", minval=0.1, step=1.0, group=gpRisk,
                 tooltip="Distancia en puntos/ticks que se colocará el TP por delante del precio actual.")

useFixedLotIn    = input.bool(false, "¿Usar Lote Fijo? (True=Fijo, False=Riesgo %)", group=gpRisk)
fixedLotValIn    = input.float(0.01, "Valor de Lote Fijo (Lotes MT5, ej: 0.01)", group=gpRisk)
maxRiskPercIn    = input.float(5.0, "Riesgo Máximo Permitido por Trade (% Balance)", minval=0.1, maxval=100.0, group=gpRisk)
maxSpreadPointsIn = input.float(50.0, "Spread Máximo Permitido (Puntos)", minval=0.1, group=gpRisk)
minStopsLevelIn  = input.float(0.0, "Mínimo Stop Level (Puntos)", minval=0.0, group=gpRisk)

// ════════════════════════════════════════════════════════════════════
// 3. INPUTS MANUALES (Solo si Perfil = Manual)
// ════════════════════════════════════════════════════════════════════
gpParam        = "--- PARÁMETROS MANUALES (Si perfil = Manual) ---"
emaTFInput    = input.string("Auto", "Temporalidad de EMAs", options=["Auto", "15", "30", "60", "180", "240", "1440"], group=gpParam,
                   tooltip="Auto: fuerza EMAs a 3h en intradía para filtrar ruido.")
emaFastLenIn = input.int(21,  "Período EMA Rápida manual", minval=1, group=gpParam)
emaSlowLenIn = input.int(55,  "Período EMA Lenta manual", minval=1, group=gpParam)
swingPeriodIn = input.int(8,   "Velas Swing High/Low manual", minval=2, group=gpParam)
slBufPtsIn   = input.float(2.0, "Buffer SL manual (Ticks/Puntos)", minval=0.0, group=gpParam)

useIMACDIn    = input.bool(false, "Usar iMACD manual", group=gpParam)
imacdLenIn    = input.int(35,     "Período iMACD manual", minval=1, group=gpParam)

useEMASprIn  = input.bool(true,  "Usar Abertura EMAs manual", group=gpParam)
emaSprMultIn = input.float(0.4,  "Abertura Mínima EMAs manual (× ATR)", minval=0.0, step=0.1, group=gpParam)

useHAStrIn   = input.bool(false, "Fuerza Heikin-Ashi manual", group=gpParam)
useEMA200In   = input.bool(false, "Filtro EMA 200 manual", group=gpParam)
ema200LenIn   = input.int(200,    "Período EMA 200 manual", minval=1, group=gpParam)

// Filtros específicos adicionales manuales
useATRMinIn   = input.bool(false, "Filtro ATR Mínimo manual", group=gpParam)
atrFilterLenIn = input.int(14,    "Período ATR manual", minval=1, group=gpParam)
atrMinUSDIn   = input.float(2.0,  "ATR Mínimo USD manual", minval=0.1, step=0.1, group=gpParam)
useADXIn       = input.bool(false, "Filtro ADX manual", group=gpParam)
adxLenIn       = input.int(14,     "Período ADX manual", minval=1, group=gpParam)
adxMinIn       = input.float(22.0, "ADX Mínimo manual", minval=5.0, step=1.0, group=gpParam)
useRSIIn       = input.bool(false, "Filtro RSI manual", group=gpParam)
rsiLenIn       = input.int(14,     "Período RSI manual", minval=1, group=gpParam)
rsiOBIn        = input.float(70.0, "RSI Sobrecompra manual", minval=50.0, group=gpParam)
rsiOSIn        = input.float(30.0, "RSI Sobreventa manual", maxval=50.0, group=gpParam)
useHTFIn       = input.bool(false, "Filtro HTF manual", group=gpParam)
htfEMALenIn   = input.int(50,     "Período EMA HTF manual", minval=1, group=gpParam)

// Filtro Horario General (Londres + Nueva York)
gpSes          = "--- CONTROL DE SESIÓN ---"
useSessionIn   = input.bool(false, "Usar Sesión Horaria", group=gpSes,
                   tooltip="Desactivado por defecto. Activa si solo quieres operar en horas específicas.")
sessionStrIn   = input.session("0800-1700", "Horario Operativo (UTC)", group=gpSes)

// ════════════════════════════════════════════════════════════════════
// 4. AUTODETECCIÓN Y ASIGNACIÓN DE PARÁMETROS EFECTIVOS
// ════════════════════════════════════════════════════════════════════
tickerLower = str.lower(syminfo.ticker)
isGoldSymbol    = str.contains(tickerLower, "xau") or str.contains(tickerLower, "gold")
isSilverSymbol  = str.contains(tickerLower, "xag") or str.contains(tickerLower, "silver")
isBitcoinSymbol = str.contains(tickerLower, "btc") or str.contains(tickerLower, "bitcoin")
isNasdaqSymbol  = str.contains(tickerLower, "nas100") or str.contains(tickerLower, "nasdaq") or str.contains(tickerLower, "us100") or str.contains(tickerLower, "ustec") or str.contains(tickerLower, "nq") or str.contains(tickerLower, "tech")

isGold    = assetProfile == "Oro (XAUUSD)"     or (assetProfile == "Auto" and isGoldSymbol)
isSilver  = assetProfile == "Plata (XAGUSD)"   or (assetProfile == "Auto" and isSilverSymbol)
isBitcoin = assetProfile == "Bitcoin (BTCUSD)" or (assetProfile == "Auto" and isBitcoinSymbol)
isNasdaq  = assetProfile == "Nasdaq (NAS100)"  or (assetProfile == "Auto" and isNasdaqSymbol)

// --- VARIABLEs DE LONGITUD / TIMEFRAME (Exigen tipo simple int / string, resueltas por ternarios) ---
emaTF         = isGold ? timeframe.period : isSilver ? "15" : isBitcoin ? "15" : isNasdaq ? timeframe.period : emaTFInput
emaFastLen    = isGold ? 8     : isSilver ? 9    : isBitcoin ? 9    : isNasdaq ? 9                : emaFastLenIn
emaSlowLen    = isGold ? 22    : isSilver ? 21   : isBitcoin ? 21   : isNasdaq ? 21               : emaSlowLenIn
swingPeriod   = isGold ? 8     : isSilver ? 5    : isBitcoin ? 5    : isNasdaq ? 5                : swingPeriodIn
imacdLen      = isGold ? 35    : isSilver ? 35   : isBitcoin ? 35   : isNasdaq ? 35               : imacdLenIn
ema200Len     = isGold ? 200   : isSilver ? 200  : isBitcoin ? 200  : isNasdaq ? 200              : ema200LenIn
atrFilterLen  = isGold ? 14    : isSilver ? 14   : isBitcoin ? 14   : isNasdaq ? 14               : atrFilterLenIn
adxLen        = isGold ? 14    : isSilver ? 14   : isBitcoin ? 14   : isNasdaq ? 14               : adxLenIn
rsiLen        = isGold ? 14    : isSilver ? 14   : isBitcoin ? 14   : isNasdaq ? 14               : rsiLenIn
htfEMALen     = isGold ? 50    : isSilver ? 50   : isBitcoin ? 50   : isNasdaq ? 50               : htfEMALenIn

// --- VARIABLES DINÁMICAS (Se inicializan con los inputs y se modifican mediante bloques IF/ELSE) ---
slBufferPts   = slBufPtsIn
rrRatio        = rrRatioIn
useBE          = useBEIn
beRatio        = beRatioIn
useIMACD       = useIMACDIn
useEMASpread  = useEMASprIn
emaSpreadMult = emaSprMultIn
useHAStrength = useHAStrIn
useEMA200      = useEMA200In
useATRMin     = useATRMinIn
atrMinUSD     = atrMinUSDIn
useADX         = useADXIn
adxMin         = adxMinIn
useRSI         = useRSIIn
rsiOB          = rsiOBIn
rsiOS          = rsiOSIn
useHTF         = useHTFIn
useTPChase     = useTPChaseIn
tpChasePts     = tpChasePtsIn
tpChaseOffset  = tpChaseOffsetIn
useSession     = useSessionIn
sessionStr     = sessionStrIn
useFixedLot     = useFixedLotIn
fixedLotValue   = fixedLotValIn
maxRiskPerc     = maxRiskPercIn
maxSpreadPoints = maxSpreadPointsIn
minStopsLevel   = minStopsLevelIn

if isGold
    slBufferPts    := 0.3
    rrRatio        := 3.3
    useBE          := true,      beRatio        := 1.5   // Asegura BE a 1.5x de beneficio para proteger el capital
    useIMACD       := true                               // Activado: Filtra rangos cuando md == 0.0
    useEMASpread   := true,      emaSpreadMult  := 0.15  // Más estricto: evita falsas rupturas
    useHAStrength  := false
    useEMA200      := true
    useATRMin      := true,      atrMinUSD      := 3.5
    useADX         := true,      adxMin         := 22.0  // Exige tendencia más fuerte
    useRSI         := false,     rsiOB          := 70.0,    rsiOS        := 30.0
    useHTF         := false
    useTPChase     := true,      tpChasePts     := 12.0,    tpChaseOffset := 12.0
    useSession     := true,      sessionStr     := "0700-1700"
    useFixedLot    := false,     fixedLotValue  := 0.01,    maxRiskPerc   := 5.0,     minStopsLevel := 0.0
else if isSilver
    slBufferPts   := 0.0
    rrRatio        := 2.5
    useBE          := true,     beRatio        := 1.0
    useIMACD       := true
    useEMASpread  := false,    emaSpreadMult := 0.0
    useHAStrength := true
    useEMA200      := true
    useATRMin     := false,    atrMinUSD     := 2.0
    useADX         := false,    adxMin        := 22.0
    useRSI         := false,    rsiOB         := 70.0,    rsiOS        := 30.0
    useHTF         := false
    useTPChase     := true,     tpChasePts     := 2.0,    tpChaseOffset := 2.0
    useSession     := false
    useFixedLot    := false,    fixedLotValue  := 0.01,    maxRiskPerc   := 5.0,     minStopsLevel := 0.0
else if isBitcoin
    slBufferPts   := 0.0
    rrRatio        := 1.8
    useBE          := true,     beRatio        := 1.0
    useIMACD       := true
    useEMASpread  := true,     emaSpreadMult := 0.3
    useHAStrength := true
    useEMA200      := true
    useATRMin     := false,    atrMinUSD     := 2.0
    useADX         := false,    adxMin        := 22.0
    useRSI         := true,     rsiOB         := 70.0,    rsiOS        := 0.0
    useHTF         := false
    useTPChase     := true,     tpChasePts     := 150.0,   tpChaseOffset := 150.0
    useSession     := false
    useFixedLot    := false,    fixedLotValue  := 0.01,    maxRiskPerc   := 5.0,     minStopsLevel := 0.0
else if isNasdaq
    slBufferPts   := 0.0
    rrRatio        := 1.5
    useBE          := true,     beRatio        := 1.0
    useIMACD       := false
    useEMASpread  := false,    emaSpreadMult := 0.0
    useHAStrength := false
    useEMA200      := false
    useATRMin     := false,    atrMinUSD     := 2.0
    useADX         := false,    adxMin        := 22.0
    useRSI         := false,    rsiOB         := 75.0,    rsiOS        := 25.0
    useHTF         := false
    useTPChase     := true,     tpChasePts     := 15.0,    tpChaseOffset := 15.0
    useSession     := false
    useFixedLot    := false,    fixedLotValue  := 0.01,    maxRiskPerc   := 5.0,     minStopsLevel := 0.0

// --- VALIDACIÓN DE TEMPORALIDAD CORRECTA EN TRADINGVIEW ---
correctTF = isGold ? "15" : isSilver ? "30" : isBitcoin ? "30" : isNasdaq ? "5" : ""
if correctTF != "" and timeframe.period != correctTF
    runtime.error("Temporalidad incorrecta para " + (isGold ? "Oro (XAUUSD)" : isSilver ? "Plata (XAGUSD)" : isBitcoin ? "Bitcoin (BTCUSD)" : "Nasdaq (NAS100)") + ". Por favor, cambie el timeframe del gráfico a " + (isGold ? "15 minutos (15m)" : isSilver or isBitcoin ? "30 minutos (30m)" : "5 minutos (5m)") + " para el correcto funcionamiento de la estrategia.")

// ════════════════════════════════════════════════════════════════════
// 5. CÁLCULO DE VELAS HEIKIN-ASHI RECURSIVAS NATIVAS
// ════════════════════════════════════════════════════════════════════
var float haOpen = na
haClose = (open + high + low + close) / 4
haOpen := na(haOpen[1]) ? (open + close) / 2 : (haOpen[1] + haClose[1]) / 2
haHigh = math.max(high, math.max(haOpen, haClose))
haLow  = math.min(low,  math.min(haOpen, haClose))

haGreen = haClose > haOpen
haRed   = haClose < haOpen

// Pintar velas HA semi-transparentes de fondo
plotcandle(haOpen, haHigh, haLow, haClose, title="Velas Heikin-Ashi",
           color=haGreen ? color.new(color.green, 85) : color.new(color.red, 85),
           wickcolor=haGreen ? color.new(color.green, 80) : color.new(color.red, 80),
           bordercolor=na)

// ════════════════════════════════════════════════════════════════════
// 6. RESOLUCIÓN DE TEMPORALIDADES MTF Y MEDIAS MÓVILES
// ════════════════════════════════════════════════════════════════════
string resolvedTF = emaTF
if emaTF == "Auto"
    if timeframe.isminutes
        if timeframe.multiplier <= 180
            resolvedTF := "180" // Forzado a 3h para cualquier gráfico intradía en el Oro
        else
            resolvedTF := "1440"
    else if timeframe.isdaily
        resolvedTF := "W"
    else
        resolvedTF := "M"

// Cálculo de EMAs mediante request.security en la temporalidad resuelta
emaFastBase = ta.ema(close, emaFastLen)
emaSlowBase = ta.ema(close, emaSlowLen)
ema200Base  = ta.ema(close, ema200Len)

emaFast = request.security(syminfo.tickerid, resolvedTF, emaFastBase, lookahead=barmerge.lookahead_off)
emaSlow = request.security(syminfo.tickerid, resolvedTF, emaSlowBase, lookahead=barmerge.lookahead_off)
ema200  = request.security(syminfo.tickerid, resolvedTF, ema200Base, lookahead=barmerge.lookahead_off)

plot(emaFast, "EMA Rápida", color=color.new(color.lime, 10), linewidth=2)
plot(emaSlow, "EMA Lenta",  color=color.new(color.red,  10), linewidth=2)
plot(useEMA200 ? ema200 : na, "EMA 200", color=color.new(color.blue, 30), linewidth=1, linestyle=plot.linestyle_dashed)

// ════════════════════════════════════════════════════════════════════
// 7. CÁLCULO DE INDICADORES DE FILTRO
// ════════════════════════════════════════════════════════════════════

// --- FILTRO DE CONTROL HORARIO ---
inSession = not useSession or not na(time(timeframe.period, sessionStr, "UTC"))

// --- FILTRO DE ABERTURA DE EMAs ---
distanciaEMAs = math.abs(emaFast - emaSlow)
aberturaOK    = not useEMASpread or (distanciaEMAs >= (ta.atr(14) * emaSpreadMult))

// --- FILTRO IMPULSE MACD ---
calcZLEMA(src, length) =>
    ema1 = ta.ema(src, length)
    ema2 = ta.ema(ema1, length)
    d = ema1 - ema2
    ema1 + d

imacdSrc = hlc3
hi = ta.rma(high, imacdLen)
lo = ta.rma(low, imacdLen)
mi = calcZLEMA(imacdSrc, imacdLen)
md = mi > hi ? mi - hi : mi < lo ? mi - lo : 0.0

imacdLongOK  = not useIMACD or (md >= 0.0)   // md==0.0 en zona neutra al salir del rango: permitido
imacdShortOK = not useIMACD or (md <= 0.0)   // md==0.0 en zona neutra al salir del rango: permitido

// --- FILTROS DE OPTIMIZACIÓN SECUNDARIOS ---
ema200LongOK  = not useEMA200 or (close > ema200)
ema200ShortOK = not useEMA200 or (close < ema200)

haStrengthLong  = not useHAStrength or (haLow  == haOpen)
haStrengthShort = not useHAStrength or (haHigh == haOpen)

// Exigir que el giro de color Heikin-Ashi sea reciente (máximo 6 velas)
haColorChangeLong  = ta.barssince(haClose[1] < haOpen[1] and haClose > haOpen) <= 6
haColorChangeShort = ta.barssince(haClose[1] > haOpen[1] and haClose < haOpen) <= 6

// Filtros específicos de Oro adicionales
atrVal  = ta.atr(atrFilterLen)
atrOK   = not useATRMin or (atrVal >= atrMinUSD)

[adxVal, diPlus, diMinus] = ta.dmi(adxLen, adxLen)
adxOK = not useADX or (adxVal >= adxMin)

rsiVal      = ta.rsi(close, rsiLen)
rsiLongOK  = not useRSI or (rsiVal < rsiOB)
rsiShortOK = not useRSI or (rsiVal > rsiOS)

htfEMA      = request.security(syminfo.tickerid, "60", ta.ema(close, htfEMALen), lookahead=barmerge.lookahead_off)
htfLongOK  = not useHTF or (close > htfEMA)
htfShortOK = not useHTF or (close < htfEMA)

// ════════════════════════════════════════════════════════════════════
// 8. CONDICIONES DE ALINEACIÓN Y GATILLOS
// ════════════════════════════════════════════════════════════════════
isLongAligned  = (emaFast > emaSlow) and haGreen and
                   imacdLongOK  and ema200LongOK  and haStrengthLong  and
                   haColorChangeLong and
                   inSession     and aberturaOK     and atrOK            and
                   adxOK         and rsiLongOK      and htfLongOK

isShortAligned = (emaFast < emaSlow) and haRed and
                   imacdShortOK and ema200ShortOK and haStrengthShort and
                   haColorChangeShort and
                   inSession     and aberturaOK     and atrOK            and
                   adxOK         and rsiShortOK     and htfShortOK

// Confirmación de velas consecutivas
confirmBars = 1
var int longCount  = 0
var int shortCount = 0
longCount  := isLongAligned  ? longCount[1]  + 1 : 0
shortCount := isShortAligned ? shortCount[1] + 1 : 0

triggerLong  = longCount  >= confirmBars and longCount[1]  < confirmBars
triggerShort = shortCount >= confirmBars and shortCount[1] < confirmBars

// ════════════════════════════════════════════════════════════════════
// 9. GESTIÓN DEL RIESGO Y DETERMINACIÓN DEL NIVELES DE SL/TP
// ════════════════════════════════════════════════════════════════════
lowestLow   = ta.lowest(low, swingPeriod)
highestHigh = ta.highest(high, swingPeriod)
slBuffer    = slBufferPts * syminfo.mintick

var float pendingSL = na
var float pendingTP = na

if triggerLong
    slVal = lowestLow - slBuffer
    risk = close - slVal
    minSLDist = minStopsLevel * syminfo.mintick
    if risk < minSLDist
        risk := minSLDist
    pendingSL := close - risk
    if (close - pendingSL) <= 0
        pendingSL := close - syminfo.mintick
    pendingTP := useTP ? (close + risk * rrRatio) : na

if triggerShort
    slVal = highestHigh + slBuffer
    risk = slVal - close
    minSLDist = minStopsLevel * syminfo.mintick
    if risk < minSLDist
        risk := minSLDist
    pendingSL := close + risk
    if (pendingSL - close) <= 0
        pendingSL := close + syminfo.mintick
    pendingTP := useTP ? (close - risk * rrRatio) : na

// ════════════════════════════════════════════════════════════════════
// 10. VARIABLES PERSISTENTES Y EJECUCIÓN DE ENTRADAS
// ════════════════════════════════════════════════════════════════════
var float activeSL    = na
var float activeTP    = na
var float trailStep   = na
var float entryP      = na
var bool  beTriggered = false

// Cálculo de lotaje en base a riesgo inicial o lote fijo
contractSize = isGold ? 100.0 : isSilver ? 5000.0 : isBitcoin ? 1.0 : isNasdaq ? 1.0 : 100.0
riskAmount   = strategy.equity * (riskPerc / 100.0)
riskDist     = math.abs(close - pendingSL)
qty          = 0.0

if useFixedLot
    qty := fixedLotValue * contractSize
else
    qty := riskDist > 0 ? riskAmount / (riskDist * syminfo.pointvalue) : 0.0

// 5. PROTECCIÓN DE SOBRE-EXPOSICIÓN (FILTRO DE RIESGO MÁXIMO)
riskInMoney  = riskDist * qty * syminfo.pointvalue
maxRiskMoney = strategy.equity * (maxRiskPerc / 100.0)
riskMaxOk    = riskInMoney <= maxRiskMoney

// Simulación de spread
spread = 0.0
spreadOk = spread <= maxSpreadPoints

if triggerLong and strategy.position_size == 0 and riskMaxOk and spreadOk
    strategy.entry("Long", strategy.long, qty=qty)

if triggerShort and strategy.position_size == 0 and riskMaxOk and spreadOk
    strategy.entry("Short", strategy.short, qty=qty)

// Apertura del trade detectada
posOpened = ta.change(strategy.position_size) != 0 and strategy.position_size != 0

if posOpened
    entryP      := strategy.position_avg_price
    activeSL    := pendingSL
    activeTP    := pendingTP
    trailStep   := math.abs(entryP - activeSL) / 5.0
    beTriggered := false

// ════════════════════════════════════════════════════════════════════
// 11. MOTOR DE GESTIÓN DINÁMICA: BREAK-EVEN Y TRAILING STOP
// ════════════════════════════════════════════════════════════════════

// --- PERSECUCIÓN DE TAKE PROFIT (TP CHASING) ---
// tpChasePts y tpChaseOffset son en puntos reales de precio (ej: 20 = $20 en Oro)
if strategy.position_size != 0 and useTPChase and not na(activeTP)
    if strategy.position_size > 0
        if (activeTP - high) <= tpChasePts
            activeTP := high + tpChaseOffset
    else if strategy.position_size < 0
        if (low - activeTP) <= tpChasePts
            activeTP := low - tpChaseOffset

// --- ACTIVACIÓN DEL BREAK-EVEN ---
if strategy.position_size != 0 and useBE and not beTriggered
    distanciaInicial = math.abs(entryP - pendingSL)
    if strategy.position_size > 0
        recorrido = high - entryP
        if recorrido >= (distanciaInicial * beRatio)
            activeSL := entryP
            beTriggered := true
    else if strategy.position_size < 0
        recorrido = entryP - low
        if recorrido >= (distanciaInicial * beRatio)
            activeSL := entryP
            beTriggered := true

// --- GESTIÓN DEL TRAILING STOP POR TERCIOS ---
if strategy.position_size > 0
    recorrido = high - entryP
    niveles = math.floor(recorrido / trailStep)
    if niveles > 0
        initialSL = entryP - (trailStep * 5.0)
        nuevoSL = initialSL + (trailStep * niveles)
        if nuevoSL > activeSL
            activeSL := nuevoSL

else if strategy.position_size < 0
    recorrido = entryP - low
    niveles = math.floor(recorrido / trailStep)
    if niveles > 0
        initialSL = entryP + (trailStep * 5.0)
        nuevoSL = initialSL - (trailStep * niveles)
        if nuevoSL < activeSL or na(activeSL)
            activeSL := nuevoSL

// Reseteo al cerrar posición
if strategy.position_size == 0
    activeSL    := na
    activeTP    := na
    trailStep   := na
    entryP      := na
    beTriggered := false

// Ejecución de salidas — se llama cada barra para que el TP chase actualice el limit dinámicamente
if strategy.position_size > 0
    strategy.exit("Exit", from_entry="Long",  stop=activeSL, limit=activeTP)
else if strategy.position_size < 0
    strategy.exit("Exit", from_entry="Short", stop=activeSL, limit=activeTP)

// ════════════════════════════════════════════════════════════════════
// 12. PLOTS DE NIVELES Y TABLA DE CONTROL
// ════════════════════════════════════════════════════════════════════
plot(strategy.position_size != 0 ? activeSL : na, "Stop Loss",   color=color.red,   style=plot.style_linebr, linewidth=2)
plot(strategy.position_size != 0 and useTP ? activeTP : na, "Take Profit", color=color.green, style=plot.style_linebr, linewidth=2)

// Tabla de estadísticas
var table mainTable = table.new(position.top_right, 2, 10,
     bgcolor=color.new(color.black, 15), border_width=1, border_color=color.gray)

if barstate.islast
    inTrade    = strategy.position_size != 0
    atrDisplay = str.tostring(atrVal, "#.##") + " USD"
    
    profileName = isGold ? "ORO (Auto)" : isSilver ? "PLATA (Auto)" : isBitcoin ? "BTC (Auto)" : isNasdaq ? "NASDAQ (Auto)" : "MANUAL"
    tfSugerido  = isGold ? "15min" : isSilver ? "30min" : isBitcoin ? "30min" : isNasdaq ? "5min" : "-"
    displayTF   = resolvedTF == "180" ? "3h" : resolvedTF == "240" ? "4h" : resolvedTF == "60" ? "1h" : resolvedTF == "30" ? "30m" : resolvedTF == "1440" ? "1d" : resolvedTF
    imacdStatus = not useIMACD ? "DESACTIVADO" : md == 0.0 ? "RANGO" : md > 0.0 ? "ALCISTA" : "BAJISTA"
    imacdColor  = not useIMACD ? color.gray   : md == 0.0 ? color.orange : md > 0.0 ? color.green : color.red

    table.cell(mainTable, 0, 0, "Estrategia:",  text_color=color.white,  text_size=size.small)
    table.cell(mainTable, 1, 0, "HA_EMA MULTI",  text_color=color.yellow, text_size=size.small)

    table.cell(mainTable, 0, 1, "Perfil:",      text_color=color.white,  text_size=size.small)
    table.cell(mainTable, 1, 1, profileName,   text_color=color.yellow, text_size=size.small)

    table.cell(mainTable, 0, 2, "TF Sugerido:",  text_color=color.white,  text_size=size.small)
    table.cell(mainTable, 1, 2, tfSugerido,     text_color=color.yellow, text_size=size.small)

    table.cell(mainTable, 0, 3, "Estado:",       text_color=color.white, text_size=size.small)
    table.cell(mainTable, 1, 3, inTrade ? "DENTRO" : "BUSCANDO",
               text_color=inTrade ? color.green : color.yellow, text_size=size.small)

    table.cell(mainTable, 0, 4, "Sesión:",       text_color=color.white, text_size=size.small)
    table.cell(mainTable, 1, 4, inSession ? "ACTIVA" : "CERRADA",
               text_color=inSession ? color.green : color.gray, text_size=size.small)

    table.cell(mainTable, 0, 5, "ATR (" + timeframe.period + "):", text_color=color.white, text_size=size.small)
    table.cell(mainTable, 1, 5, atrDisplay,     text_color=color.green, text_size=size.small)

    table.cell(mainTable, 0, 6, "TF EMAs:",       text_color=color.white, text_size=size.small)
    table.cell(mainTable, 1, 6, displayTF,       text_color=color.yellow, text_size=size.small)

    table.cell(mainTable, 0, 7, "iMACD:",        text_color=color.white, text_size=size.small)
    table.cell(mainTable, 1, 7, imacdStatus,    text_color=imacdColor, text_size=size.small)

    table.cell(mainTable, 0, 8, "Equidad:",      text_color=color.white, text_size=size.small)
    table.cell(mainTable, 1, 8, "$" + str.tostring(strategy.equity, "#.##"),
               text_color=color.green, text_size=size.small)

    table.cell(mainTable, 0, 9, "Rendimiento:",  text_color=color.white, text_size=size.small)
    table.cell(mainTable, 1, 9, str.tostring(strategy.netprofit, "#.##") + " USD",
               text_color=strategy.netprofit >= 0 ? color.green : color.red, text_size=size.small)
