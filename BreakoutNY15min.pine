//@version=6
// ╔══════════════════════════════════════════════════════════════════╗
// ║  BreakoutNY 5min  –  ARCHIVO MASTER (Pine Script)               ║
// ║  Al replicar a MQ5, preservar TODAS las secciones [MQ5-CRITICAL]║
// ╠══════════════════════════════════════════════════════════════════╣
// ║  CHECKLIST DE TRADUCCIÓN A MQ5:                                 ║
// ║  [✓] 1. GetOwnPositionType() devuelve -1 / BUY / SELL           ║
// ║  [✓] 2. longC  bloquea si ya hay SHORT  (not in_short)          ║
// ║  [✓] 3. shortC bloquea si ya hay LONG   (not in_long)           ║
// ║  [✓] 4. Trailing por quintos (trail = tRisk / 5)                ║
// ║  [✓] 5. Filtro magicNumber en TODAS las consultas               ║
// ╚══════════════════════════════════════════════════════════════════╝
strategy('BreakoutNY 5min', overlay=true, initial_capital=450, default_qty_type=strategy.percent_of_equity, default_qty_value=2, process_orders_on_close=true)

// ─────────────────────────────────────────────
// INPUTS - GESTIÓN DE RIESGO
// ─────────────────────────────────────────────
gpRisk      = "--- GESTIÓN DE RIESGO ---"
float rr        = input.float(0.90, "RR para TP", minval=0.1, step=0.1, group=gpRisk)
int   maxTrades = input.int(3,    "Máx trades por día", minval=1, maxval=10, group=gpRisk)
float riskPerc  = input.float(2.0, "Riesgo por operación (%)", minval=0.1, maxval=10.0, group=gpRisk, tooltip="Porcentaje de la equidad a arriesgar basado en el SL inicial")

// ─────────────────────────────────────────────
// INPUTS - FILTROS DE ENTRADA / RANGO
// ─────────────────────────────────────────────
gpFilters      = "--- FILTROS DE ENTRADA ---"
int   ema200LengthIn = input.int(200,  "Período EMA 200", minval=1, group=gpFilters)
bool  useImacd       = input.bool(false, "Usar Filtro Impulse MACD", group=gpFilters, tooltip="Evita falsos rompimientos alinear con la tendencia del Impulse MACD")
int   imacdLen       = input.int(34, "Período Impulse MACD", minval=1, group=gpFilters)

// ─────────────────────────────────────────────
// INPUTS - PARÁMETROS ATR (TP)
// ─────────────────────────────────────────────
gpAtr       = "--- PARÁMETROS ATR ---"
int   atrPeriod      = input.int(14, "Período ATR", minval=1, group=gpAtr)
float atrMultiplier  = input.float(1.5, "Multiplicador ATR", minval=0.1, step=0.1, group=gpAtr)

// ─────────────────────────────────────────────
// AUTODETECCIÓN DE INSTRUMENTO
// ─────────────────────────────────────────────
tickerLower = str.lower(syminfo.ticker)
isNasdaq    = str.contains(tickerLower, "nas100") or str.contains(tickerLower, "nasdaq") or str.contains(tickerLower, "us100") or str.contains(tickerLower, "nq")
isUS30      = str.contains(tickerLower, "us30") or str.contains(tickerLower, "dow") or str.contains(tickerLower, "ym")
isGold      = str.contains(tickerLower, "xau") or str.contains(tickerLower, "gold")

// ============================================================================
// VARIABLES GLOBALES (Definidas al inicio y comentadas para su uso)
// ============================================================================

// Variables de Estrategia reasignables por Instrumento
float effectiveRr        = rr              // Ratio Riesgo Beneficio efectivo para el TP
int   effectiveMaxTrades = maxTrades       // Cantidad máxima de trades permitidos por día

// Parámetros de Indicadores reasignables por Instrumento
int ema200Length         = ema200LengthIn  // Período de la media móvil exponencial (EMA)
int imacdLength          = imacdLen        // Período del indicador Impulse MACD
float effectiveAtrMult   = atrMultiplier   // Multiplicador ATR efectivo para el TP

if isNasdaq
    effectiveRr        := 1.2
    effectiveMaxTrades := 2
    ema200Length       := 150
   // effectiveAtrMult   := 1.5
else if isGold
    effectiveRr        := 1.5
    effectiveMaxTrades := 2
    ema200Length       := 200
    //effectiveAtrMult   := 2.0
else if isUS30
    effectiveRr        := 1.0
    effectiveMaxTrades := 2
    ema200Length       := 200
    //effectiveAtrMult   := 1.5

// Variables de Estado y Tracking de Trades
var float tEnt             = na   // Precio de entrada real de la operación
var float tSl              = na   // Stop Loss dinámico activo (trailing)
var float tTp              = na   // Take Profit activo
var float tRisk            = na   // Riesgo inicial en puntos (distancia entrada - SL inicial)
var int   tradesToday      = 0    // Conteo de operaciones ejecutadas hoy
var int   lastDayId        = 0    // ID único del día actual para control de reset diario
var int   sessionStartBar  = na   // Índice de barra del inicio de la sesión en el gráfico principal

// Zona horaria y horario actual
string localTimezone       = syminfo.timezone // Zona horaria local del símbolo
string activeTimezone      = input.string("America/New_York", "Zona Horaria Activa", options=["America/New_York", "America/Mexico_City", "Local"], group="--- HORARIO DEL RANGO ---")
string targetTimezone      = activeTimezone == "Local" ? localTimezone : activeTimezone

// Definición de horarios de sesión (de 9:30 a 9:45 NY y de 8:30 a 8:45 CDMX)
int nyStartHour            = 9   // Hora de inicio NY
int nyStartMin             = 30  // Minuto de inicio NY
int nyEndHour              = 9   // Hora de fin NY
int nyEndMin               = 45  // Minuto de fin NY

int cdmxStartHour          = 8   // Hora de inicio CDMX
int cdmxStartMin           = 30  // Minuto de inicio CDMX
int cdmxEndHour            = 8   // Hora de fin CDMX
int cdmxEndMin             = 45  // Minuto de fin CDMX

// Variables de sesión activas dependientes de la zona horaria
int sessionStartHour       = targetTimezone == "America/Mexico_City" ? cdmxStartHour : nyStartHour
int sessionStartMin        = targetTimezone == "America/Mexico_City" ? cdmxStartMin  : nyStartMin
int sessionEndHour         = targetTimezone == "America/Mexico_City" ? cdmxEndHour   : nyEndHour
int sessionEndMin          = targetTimezone == "America/Mexico_City" ? cdmxEndMin    : nyEndMin

// Variables de lectura horaria en New York (NY)
int nyHour                 = hour(time, "America/New_York")
int nyMinute               = minute(time, "America/New_York")

// Variables de lectura horaria en Ciudad de México (CDMX)
int cdmxHour               = hour(time, "America/Mexico_City")
int cdmxMinute             = minute(time, "America/Mexico_City")

// Variables de lectura horaria local del Símbolo
int localHour              = hour(time, localTimezone)
int localMinute            = minute(time, localTimezone)

// Variables de lectura horaria activa del gráfico para el reset diario
int currentHour            = hour(time, targetTimezone)
int currentMinute          = minute(time, targetTimezone)
int currentYear            = year(time, targetTimezone)
int currentMonth           = month(time, targetTimezone)
int currentDay             = dayofmonth(time, targetTimezone)

// Objetos gráficos de la sesión NY
var box rangeBox           = na   // Caja naranja que enmarca el rango de la sesión

// Líneas de dibujo para niveles de SL y TP iniciales (ancho de 1 vela)
var line slLineInicial     = na   // Línea horizontal del Stop Loss inicial (roja, sólida, ancho de 1 vela)
var line tpLineInicial     = na   // Línea horizontal del Take Profit inicial (verde, sólida, ancho de 1 vela)

// Líneas de dibujo para niveles de SL y TP activos (que se mueven mientras la posición no sea cerrada)
var line slLine            = na   // Línea horizontal del Stop Loss activo/trailing (roja, sólida)
var line tpLine            = na   // Línea horizontal del Take Profit activo (verde, sólida)

int barEntry  = na

// ─────────────────────────────────────────────
// FUNCIONES DE CÁLCULO (SL, TP, TRAILING, LOTAJE)
// ─────────────────────────────────────────────

// Calcular Take Profit dinámico basado en ATR (mínimo el TP definido por la estrategia)
calcTP(isLong, entry, sl, rrRatio, atrVal, atrMult) =>
    float risk = math.abs(entry - sl)
    float fixedTp = risk * rrRatio
    float atrTp = not na(atrVal) ? atrVal * atrMult : 0.0
    float tpDistance = math.max(atrTp, fixedTp)
    isLong ? entry + tpDistance : entry - tpDistance

// Calcular Trailing Stop dinámico por quintos
calcTrailingSL(isLong, entry, currentSl, risk, priceHigh, priceLow, stepsDiv) =>
    float nuevoSl = currentSl
    float trail = risk / stepsDiv
    if isLong
        float steps = math.max(0.0, math.floor((priceHigh - entry) / trail))
        nuevoSl := math.max(currentSl, (entry - risk) + steps * trail)
    else
        float steps = math.max(0.0, math.floor((entry - priceLow) / trail))
        nuevoSl := math.min(currentSl, (entry + risk) - steps * trail)
    nuevoSl

// Calcular lotaje dinámico basado en riesgo
calcQty(equity, riskPct, slDist) =>
    float montoRiesgo = equity * (riskPct / 100.0)
    float pv          = syminfo.pointvalue
    pv > 0 and slDist > 0 ? montoRiesgo / (slDist * pv) : 0.0

// Lógica de cálculo del rango NY de 15m ejecutada dentro de la temporalidad de 5 minutos
calcularRango5m(tz, sHour, sMin, eHour, eMin) =>
    var float rHigh5 = na
    var float rLow5  = na
    var int lastDayId5 = 0
    int yr = year(time, tz)
    int mon = month(time, tz)
    int dy = dayofmonth(time, tz)
    int dayId = yr * 10000 + mon * 100 + dy
    if dayId != lastDayId5
        rHigh5 := na
        rLow5  := na
        lastDayId5 := dayId
    int hr = hour(time, tz)
    int mn = minute(time, tz)
    int barMins5 = hr * 60 + mn
    int startM = sHour * 60 + sMin
    int endM   = eHour * 60 + eMin
    bool inSess5 = barMins5 >= startM and barMins5 < endM
    if inSess5
        rHigh5 := na(rHigh5) ? high : math.max(rHigh5, high)
        rLow5  := na(rLow5)  ? low  : math.min(rLow5,  low)
    [rHigh5, rLow5]

// Petición de rango calculado en temporalidad de 5 minutos (solo velas cerradas)
[rHighRaw, rLowRaw] = request.security(syminfo.tickerid, "5", calcularRango5m(targetTimezone, sessionStartHour, sessionStartMin, sessionEndHour, sessionEndMin), barmerge.gaps_off, barmerge.lookahead_off)

// Obtener datos OHLC de 5 minutos (solo velas cerradas)
float c5 = request.security(syminfo.tickerid, "5", close[1], barmerge.gaps_off, barmerge.lookahead_off)
float h5 = request.security(syminfo.tickerid, "5", high[1], barmerge.gaps_off, barmerge.lookahead_off)
float l5 = request.security(syminfo.tickerid, "5", low[1], barmerge.gaps_off, barmerge.lookahead_off)

// EMA 200 calculada en temporalidad de 5 minutos (solo velas cerradas)
float ema200_5m = request.security(syminfo.tickerid, "5", ta.ema(close, ema200Length)[1], barmerge.gaps_off, barmerge.lookahead_off)

// ATR calculado en temporalidad de 5 minutos (solo velas cerradas)
float atr5 = request.security(syminfo.tickerid, "5", ta.atr(atrPeriod)[1], barmerge.gaps_off, barmerge.lookahead_off)

// Impulse MACD calculado en temporalidad de 5 minutos (solo velas cerradas)
calcularImacd5m(len) =>
    ema1 = ta.ema(hlc3, len)
    ema2 = ta.ema(ema1, len)
    mi = ema1 + (ema1 - ema2)
    hi = ta.rma(high, len)
    lo = ta.rma(low, len)
    mi > hi ? mi - hi : mi < lo ? mi - lo : 0.0

float md5 = request.security(syminfo.tickerid, "5", calcularImacd5m(imacdLength)[1], barmerge.gaps_off, barmerge.lookahead_off)
bool imacdLongOk5  = not useImacd or (md5 > 0.0)
bool imacdShortOk5 = not useImacd or (md5 < 0.0)

// ─────────────────────────────────────────────
// INDICADORES PARA EL GRÁFICO ACTUAL
// ─────────────────────────────────────────────
plot(ema200_5m, "EMA 200 (5m)", color=color.new(color.blue, 30), linewidth=2)

// ─────────────────────────────────────────────
// RESETEO DIARIO EN EL GRÁFICO ACTUAL
// ─────────────────────────────────────────────
int currentDayId = currentYear * 10000 + currentMonth * 100 + currentDay
bool isNewDay = currentDayId != lastDayId

if isNewDay
    tradesToday     := 0
    lastDayId       := currentDayId
    sessionStartBar := na

// ─────────────────────────────────────────────
// CONSTRUCCIÓN DEL RANGO EN EL GRÁFICO ACTUAL (Para visualización)
// ─────────────────────────────────────────────
int barMins    = currentHour * 60 + currentMinute
int startMins  = sessionStartHour * 60 + sessionStartMin
int endMins    = sessionEndHour * 60 + sessionEndMin
bool inSession = barMins >= startMins and barMins < endMins

if inSession
    if na(sessionStartBar)
        sessionStartBar := bar_index

// ─────────────────────────────────────────────
// CONDICIONES DE ENTRADA (Basadas en velas cerradas de 5m)
// ─────────────────────────────────────────────
bool afterSession = not inSession and not na(rHighRaw) and not na(rLowRaw)
bool bodyUp = c5 > rHighRaw
bool bodyDn = c5 < rLowRaw

// [MQ5-CRITICAL #1] DETECCIÓN DE DIRECCIÓN DE POSICIÓN
bool inLong  = strategy.position_size > 0
bool inShort = strategy.position_size < 0

// [MQ5-CRITICAL #2] FILTRO DE POSICIÓN CONTRARIA EN CONDICIONES DE ENTRADA
bool longC  = afterSession and bodyUp and c5 > ema200_5m and imacdLongOk5 and not inShort and tradesToday < effectiveMaxTrades
bool shortC = afterSession and bodyDn and c5 < ema200_5m and imacdShortOk5 and not inLong and tradesToday < effectiveMaxTrades

// ─────────────────────────────────────────────
// ENTRADAS
// ─────────────────────────────────────────────
if longC
    tEnt        := close
    tSl         := rLowRaw
    tRisk       := math.abs(close - rLowRaw)
    tTp         := calcTP(true, close, rLowRaw, effectiveRr, atr5, effectiveAtrMult)
    tradesToday := tradesToday + 1
    qty          = calcQty(strategy.equity, riskPerc, tRisk)
    strategy.entry("L", strategy.long, qty=qty)
    label.new(bar_index, low, "↑ COMPRA", color=color.green, textcolor=color.white, style=label.style_label_up, size=size.small) 
    slLineInicial := line.new(bar_index, tSl, bar_index + 1, tSl, color=color.red, style=line.style_solid, width=2)
    tpLineInicial := line.new(bar_index, tTp, bar_index + 1, tTp, color=color.green, style=line.style_solid, width=2)


if shortC
    tEnt        := close
    tSl         := rHighRaw
    tRisk       := math.abs(close - rHighRaw)
    tTp         := calcTP(false, close, rHighRaw, effectiveRr, atr5, effectiveAtrMult)
    tradesToday := tradesToday + 1
    qty          = calcQty(strategy.equity, riskPerc, tRisk)
    strategy.entry("S", strategy.short, qty=qty)
    label.new(bar_index, high, "↓ VENTA", color=color.red, textcolor=color.white, style=label.style_label_down, size=size.small)
    slLineInicial := line.new(bar_index, tSl, bar_index + 1, tSl, color=color.red, style=line.style_solid, width=2)
    tpLineInicial := line.new(bar_index, tTp, bar_index + 1, tTp, color=color.green, style=line.style_solid, width=2)




// ─────────────────────────────────────────────
// TRAILING STOP CALCULADO EN VELAS DE 5M
// ─────────────────────────────────────────────
// [MQ5-CRITICAL #3] TRAILING STOP POR QUINTOS
// ─────────────────────────────────────────────
bool new5mBar = ta.change(time("5")) != 0

if strategy.position_size != 0 and not na(tRisk)
    if new5mBar
        tSl := calcTrailingSL(strategy.position_size > 0, tEnt, tSl, tRisk, h5, l5, 5.0)
    strategy.exit("Exit", stop=tSl, limit=tTp)

// ─────────────────────────────────────────────
// VISUALIZACIÓN DEL RANGO
// ─────────────────────────────────────────────
bool isNewSession = not na(sessionStartBar) and (na(sessionStartBar[1]) or sessionStartBar != sessionStartBar[1])

// Dibujar caja naranja durante la sesión (de 9:30 a 9:45)
if inSession and not na(sessionStartBar)
    if na(rangeBox) or isNewSession
        rangeBox := box.new(left=sessionStartBar, top=rHighRaw, right=bar_index + 1, bottom=rLowRaw, bgcolor=color.new(color.orange, 90), border_color=color.orange, border_style=line.style_solid, border_width=1)
    else
        box.set_top(rangeBox, rHighRaw)
        box.set_bottom(rangeBox, rLowRaw)
        box.set_right(rangeBox, bar_index + 1)



// --- DIBUJADO DE LÍNEAS DE SL Y TP ---
posOpened = ta.change(strategy.position_size) != 0 and strategy.position_size != 0

// 2. Dibujar líneas de SL (rojo) y TP (verde) mientras la posición no sea cerrada
if strategy.position_size != 0
    int entryBar = strategy.opentrades.entry_bar_index(0)
    if na(slLine)
        slLine := line.new(entryBar, tSl, bar_index + 1, tSl, color=color.red, style=line.style_solid, width=2)
        tpLine := line.new(entryBar, tTp, bar_index + 1, tTp, color=color.green, style=line.style_solid, width=2)
    else
        line.set_xy1(slLine, entryBar, tSl)
        line.set_xy2(slLine, bar_index + 1, tSl)
        line.set_xy1(tpLine, entryBar, tTp)
        line.set_xy2(tpLine, bar_index + 1, tTp)
else
    if not na(slLine)
        line.delete(slLine)
        slLine := na
    if not na(tpLine)
        line.delete(tpLine)
        tpLine := na

// ─────────────────────────────────────────────
// DIBUJADO DE SEÑALES DE SALIDA Y TRAILING
// ─────────────────────────────────────────────
isExit   = strategy.position_size[1] != 0 and strategy.position_size == 0
isTpHit  = isExit and (strategy.position_size[1] > 0 ? high >= tTp[1] : low <= tTp[1])
isSlHit  = isExit and not isTpHit

plotshape(isTpHit, "Take Profit Hit", shape.circle, location.abovebar, color.green, size=size.small)
plotshape(isSlHit, "Stop Loss Hit", shape.circle, location.belowbar, color.red, size=size.small)
plotshape(ta.change(tSl) != 0 and strategy.position_size != 0, "Trail Moved", shape.circle, location.abovebar, color.orange, size=size.tiny)

// ─────────────────────────────────────────────
// TABLA DE ESTADÍSTICAS E INDICADOR DE CALIDAD
// ─────────────────────────────────────────────
var table mainTable = table.new(position.top_right, 2, 7, bgcolor=color.new(color.black, 15), border_width=1, border_color=color.gray)
if barstate.islast
    inTrade = strategy.position_size != 0
    table.cell(mainTable, 0, 0, "Estrategia:", text_color=color.white, text_size=size.small)
    table.cell(mainTable, 1, 0, "BreakoutNY 5m", text_color=color.yellow, text_size=size.small)
    
    table.cell(mainTable, 0, 1, "Estado:", text_color=color.white, text_size=size.small)
    table.cell(mainTable, 1, 1, inTrade ? "DENTRO" : "BUSCANDO", text_color=inTrade ? color.green : color.yellow, text_size=size.small)
    
    table.cell(mainTable, 0, 2, "Equidad:", text_color=color.white, text_size=size.small)
    table.cell(mainTable, 1, 2, "$" + str.tostring(strategy.equity, "#.##"), text_color=color.green, text_size=size.small)
    
    table.cell(mainTable, 0, 3, "Paso Trail:", text_color=color.white, text_size=size.small)
    table.cell(mainTable, 1, 3, inTrade ? str.tostring(tRisk / 5.0, "#.####") : "-", text_color=color.white, text_size=size.small)
    
    table.cell(mainTable, 0, 4, "Filtro iMACD:", text_color=color.white, text_size=size.small)
    imacdStatus = not useImacd ? "DESACTIVADO" : md5 == 0.0 ? "RANGO" : md5 > 0.0 ? "ALCISTA" : "BAJISTA"
    imacdColor  = not useImacd ? color.gray : md5 == 0.0 ? color.orange : md5 > 0.0 ? color.green : color.red
    table.cell(mainTable, 1, 4, imacdStatus, text_color=imacdColor, text_size=size.small)
    
    table.cell(mainTable, 0, 5, "Rendimiento:", text_color=color.white, text_size=size.small)
    table.cell(mainTable, 1, 5, str.tostring(strategy.netprofit, "#.##") + " USD", text_color=strategy.netprofit >= 0 ? color.green : color.red, text_size=size.small)
    
    table.cell(mainTable, 0, 6, "Calidad:", text_color=color.white, text_size=size.small)
    table.cell(mainTable, 1, 6, strategy.netprofit >= 0 ? "🟢 BUENA" : "🔴 MEJORABLE", text_color=strategy.netprofit >= 0 ? color.green : color.red, text_size=size.small)
