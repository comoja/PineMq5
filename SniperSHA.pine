//@version=6
// ══════════════════════════════════════════════════════════════════════════
// │                     SNIPER + SHA  v2.0                                │
// │          Estrategia multi-activo con gestión de riesgo completa       │
// │                                                                        │
// │  RESUMEN:                                                              │
// │  - Señal: Impulse MACD + EMA adaptativa + filtro HTF (1H)             │
// │  - SL:    ATR × multiplicador bajo/sobre el mínimo/máximo anterior    │
// │  - TP:    Precio entrada ± riesgo × RR                                │
// │  - Trail: Por tercios (BE → 50%TP → punto a punto)                   │
// │  - Filtro rango: Impulse MACD evita entradas en laterales             │
// │  - Calidad: bgcolor verde=condiciones alcistas / rojo=bajistas         │
// │                                                                        │
// │  [MQ5-CRITICAL] Magic Number: ver input "Identificación"              │
// ══════════════════════════════════════════════════════════════════════════

strategy("Sniper + SHA v2", overlay=true,
         initial_capital      = 460,
         default_qty_type     = strategy.percent_of_equity,
         default_qty_value    = 8,
         process_orders_on_close = true,
         commission_type      = strategy.commission.percent,
         commission_value     = 0.04)

// ══════════════════════════════════════════════════════════════════════════
// GRUPO: IDENTIFICACIÓN
// ══════════════════════════════════════════════════════════════════════════
gId      = "═══ Identificación ═══"
magicNum = input.int(334455, "Magic Number (referencia MQ5)", group=gId)

// ══════════════════════════════════════════════════════════════════════════
// GRUPO: TIPO DE ACTIVO
// ══════════════════════════════════════════════════════════════════════════
gActivo    = "═══ Tipo de Activo ═══"
marketType = input.string("auto", "Tipo de activo",
             options=["auto","indice","forex","crypto","plata","oro"],
             tooltip="'auto' detecta el instrumento automáticamente",
             group=gActivo)

// Detección automática (robusta frente al idioma del broker)
string tickerLower = str.lower(syminfo.ticker)
bool isSilver = str.contains(tickerLower, "xag") or str.contains(tickerLower, "silver") or str.contains(tickerLower, "plata")
bool isGold   = str.contains(tickerLower, "xau") or str.contains(tickerLower, "gold")   or str.contains(tickerLower, "oro")
bool isCrypto = syminfo.type == "crypto"
bool isForex  = syminfo.type == "forex"
bool isIndex  = str.contains(tickerLower, "nas") or str.contains(tickerLower, "us100") or str.contains(tickerLower, "us30") or str.contains(tickerLower, "us500") or str.contains(tickerLower, "spx") or str.contains(tickerLower, "dax") or str.contains(tickerLower, "ftse") or syminfo.type == "index"

// Tipo efectivo (override manual tiene prioridad)
bool effSilver = marketType == "plata"  or (marketType == "auto" and isSilver)
bool effGold   = marketType == "oro"    or (marketType == "auto" and isGold)
bool effCrypto = marketType == "crypto" or (marketType == "auto" and isCrypto)
bool effIndex  = marketType == "indice" or (marketType == "auto" and isIndex)
bool effForex  = marketType == "forex"  or (marketType == "auto" and isForex)

// ══════════════════════════════════════════════════════════════════════════
// GRUPO: GESTIÓN DE RIESGO
// ══════════════════════════════════════════════════════════════════════════
gRiesgo      = "═══ Gestión de Riesgo ═══"
riesgoPct    = input.float(1.0,  "Riesgo por operación (%)",         minval=0.1, maxval=10.0, step=0.1,  group=gRiesgo)
minRR        = input.float(1.2,  "RR mínimo (TP/SL)",                minval=0.5, maxval=5.0,  step=0.1,  group=gRiesgo)
atrMultInp   = input.float(0.5,  "Multiplicador ATR para SL",        minval=0.05, maxval=3.0, step=0.05, group=gRiesgo)
beRRInp      = input.float(0.4,  "Break-even trigger (× riesgo)",    minval=0.1, maxval=1.0,  step=0.05, group=gRiesgo, tooltip="SL sube a entrada cuando precio avanza esta fracción del riesgo inicial")
cooldownBars = input.int(8,      "Velas de enfriamiento (cooldown)", minval=0, group=gRiesgo, tooltip="Número de velas a esperar para volver a entrar tras cerrar una posición")

// ══════════════════════════════════════════════════════════════════════════
// GRUPO: FILTROS DE ENTRADA
// ══════════════════════════════════════════════════════════════════════════
gEntrada     = "═══ Filtros de Entrada ═══"
useAdxFilter = input.bool(true,  "Usar Filtro ADX",                 group=gEntrada)
adxMinInp    = input.int(23,    "ADX mínimo",                       minval=10, maxval=50,   group=gEntrada)
adxRisingInp = input.bool(false, "Exigir ADX subiendo",             group=gEntrada)
useHtfInp    = input.bool(true,  "Filtro HTF 1H (solo índices)",    group=gEntrada)
maxDistInp   = input.float(2.0,  "Distancia máx. a EMA (× ATR)",   minval=0.5, maxval=10.0, step=0.5, group=gEntrada)

// ══════════════════════════════════════════════════════════════════════════
// GRUPO: FILTRO RANGO (IMPULSE MACD)
// ══════════════════════════════════════════════════════════════════════════
gImacd        = "═══ Filtro Rango (IMACD) ═══"
useImacd      = input.bool(true,  "Usar Impulse MACD",              group=gImacd)
imacdPer      = input.int(34,    "Período IMACD",                   minval=5, maxval=200,   group=gImacd)
imacdSmooth   = input.int(9,     "Suavizado histograma",            minval=1, maxval=50,    group=gImacd)
imacdThreshPc = input.float(0.3, "Umbral mínimo (× ATR)",           minval=0.0, maxval=3.0, step=0.05, group=gImacd)

// ══════════════════════════════════════════════════════════════════════════
// GRUPO: SHA (visualización)
// ══════════════════════════════════════════════════════════════════════════
gSha   = "═══ Velas SHA ═══"
shaLen = input.int(10, "Período SHA", minval=3, maxval=50, group=gSha)

// ══════════════════════════════════════════════════════════════════════════
// PARÁMETROS ADAPTATIVOS POR TIPO DE ACTIVO
// ══════════════════════════════════════════════════════════════════════════
float atrMult = effSilver ? 0.1 : effGold ? 0.3 : effCrypto ? 0.15 : effIndex ? atrMultInp : 0.6
float beRR    = effCrypto ? 0.5 : effIndex ? beRRInp : 0.7
int   adxMin  = effIndex ? math.max(adxMinInp, 28) : (effGold or effSilver) ? 18 : adxMinInp
int   emaPer  = effSilver ? 9 : 21

// ══════════════════════════════════════════════════════════════════════════
// INDICADORES
// ══════════════════════════════════════════════════════════════════════════
emaVal         = ta.ema(close, emaPer)
[_, _, adxVal] = ta.dmi(14, 14)
atrVal         = ta.atr(14)

// Filtro ADX
bool adxOk = not useAdxFilter or (adxVal > adxMin and (adxRisingInp ? ta.rising(adxVal, 1) : true))

// Filtro HTF 1 hora
float ema1h  = request.security(syminfo.tickerid, "60", ta.ema(close, 21), lookahead=barmerge.lookahead_off)
bool htfBull = close > ema1h
bool htfBear = close < ema1h

// Impulse MACD (filtro de rango — evita mercados laterales)
imacdMi = ta.sma(close, imacdPer)
imacdMd = close > imacdMi ? close - ta.lowest(low, imacdPer) : close < imacdMi ? close - ta.highest(high, imacdPer) : 0.0
imacdSh = imacdMd - ta.sma(imacdMd, imacdSmooth)

float imacdThresh  = atrVal * imacdThreshPc
bool imacdLongOk  = not useImacd or (imacdSh > 0 and imacdSh > imacdSh[1] and math.abs(imacdSh) > imacdThresh)
bool imacdShortOk = not useImacd or (imacdSh < 0 and imacdSh < imacdSh[1] and math.abs(imacdSh) > imacdThresh)

// ══════════════════════════════════════════════════════════════════════════
// FUNCIONES Y LOGICA DE TRAILING (REGLAS.MD)
// ══════════════════════════════════════════════════════════════════════════

// Calcula el Stop Loss inicial basado en swing y ATR
calcSL(esLong, refHigh, refLow, atr, mult) =>
    esLong ? refLow - atr * mult : refHigh + atr * mult

// Calcula el Take Profit basado en riesgo × RR
calcTP(entrada, slVal, rr) =>
    float dist = math.abs(entrada - slVal)
    entrada > slVal ? entrada + dist * rr : entrada - dist * rr

// Calcula el lotaje dinámico basado en riesgo % del capital
calcLotaje(equity, riskPct, slDist) =>
    float montoRiesgo = equity * (riskPct / 100.0)
    float pv          = syminfo.pointvalue
    pv > 0 and slDist > 0 ? montoRiesgo / (slDist * pv) : 0.0

// Función para actualizar el SL dinámico en LONG (Compra)
actualizarSlLong(precioHigh, tEnt, slInicial, slTercio, tpTercio, tpDist, tStep, tSl, distSeguimiento, tRisk, beRR, tTp) =>
    float nuevoSl = tSl
    int nuevoStep = tStep
    float nuevaDist = distSeguimiento
    float nuevoTp = tTp
    
    float TP1 = tEnt + tpTercio
    float TP2 = tEnt + (tpTercio * 2.0)
    float TP3 = tEnt + tpDist
    float SL1 = slInicial + slTercio
    float BE  = tEnt
    
    // 1. Regreso inmediato (BE): si avanza la distancia de beRR, SL va a entrada (BE)
    if precioHigh >= tEnt + tRisk * beRR
        nuevoSl := math.max(nuevoSl, BE)
        if nuevoStep < 1
            nuevoStep := 1
            
    // 2. Regla especial: si el SL > TP3 * (4/6) y el precio < TP3 entonces borras el TP final y el TP3
    float slLimite = tEnt + tpDist * (4.0 / 6.0)
    if not na(nuevoTp) and nuevoSl > slLimite and precioHigh < TP3
        nuevoTp := na
    else
        // 3. Niveles por tercios
        if precioHigh >= (TP2 + (tpDist / 6.0))
            if tStep < 3
                nuevoStep := 3
                nuevoSl   := tEnt + (tpDist * 0.5)
                nuevaDist := precioHigh - nuevoSl
            else
                if not na(distSeguimiento)
                    float trailingSl = precioHigh - distSeguimiento
                    if trailingSl > tSl
                        nuevoSl := trailingSl
        else if precioHigh >= TP2
            nuevoSl := math.max(nuevoSl, TP1)
            if nuevoStep < 2
                nuevoStep := 2
        else if precioHigh >= TP1
            nuevoSl := math.max(nuevoSl, SL1)
            
    [nuevoSl, nuevoStep, nuevaDist, nuevoTp]

// Función para actualizar el SL dinámico en SHORT (Venta)
actualizarSlShort(precioLow, tEnt, slInicial, slTercio, tpTercio, tpDist, tStep, tSl, distSeguimiento, tRisk, beRR, tTp) =>
    float nuevoSl = tSl
    int nuevoStep = tStep
    float nuevaDist = distSeguimiento
    float nuevoTp = tTp
    
    float TP1 = tEnt - tpTercio
    float TP2 = tEnt - (tpTercio * 2.0)
    float TP3 = tEnt - tpDist
    float SL1 = slInicial - slTercio
    float BE  = tEnt
    
    // 1. Regreso inmediato (BE): si cae la distancia de beRR, SL va a entrada (BE)
    if precioLow <= tEnt - tRisk * beRR
        nuevoSl := math.min(nuevoSl, BE)
        if nuevoStep < 1
            nuevoStep := 1
            
    // 2. Regla especial: si el SL > TP3 * (4/6) y el precio < TP3 entonces borras el TP final y el TP3
    float slLimite = tEnt - tpDist * (4.0 / 6.0)
    if not na(nuevoTp) and nuevoSl < slLimite and precioLow > TP3
        nuevoTp := na
    else
        // 3. Niveles por tercios
        if precioLow <= (TP2 - (tpDist / 6.0))
            if tStep < 3
                nuevoStep := 3
                nuevoSl   := tEnt - (tpDist * 0.5)
                nuevaDist := nuevoSl - precioLow
            else
                if not na(distSeguimiento)
                    float trailingSl = precioLow + distSeguimiento
                    if trailingSl < tSl
                        nuevoSl := trailingSl
        else if precioLow <= TP2
            nuevoSl := math.min(nuevoSl, TP1)
            if nuevoStep < 2
                nuevoStep := 2
        else if precioLow <= TP1
            nuevoSl := math.min(nuevoSl, SL1)
            
    [nuevoSl, nuevoStep, nuevaDist, nuevoTp]

// ══════════════════════════════════════════════════════════════════════════
// VELAS HEIKIN-ASHI SUAVIZADAS (SHA)
// ══════════════════════════════════════════════════════════════════════════
sO = ta.ema(open,  shaLen)
sC = ta.ema(close, shaLen)
var float shaOpenVal = na
shaCloseVal  = (sO + ta.ema(high, shaLen) + ta.ema(low, shaLen) + sC) / 4.0
shaOpenVal  := na(shaOpenVal) ? (sO + sC) / 2.0 : (shaOpenVal + shaCloseVal) / 2.0
fO = ta.ema(shaOpenVal,  shaLen)
fC = ta.ema(shaCloseVal, shaLen)

bool shaGreen = fC > fO
bool shaRed   = fC < fO

// ══════════════════════════════════════════════════════════════════════════
// VARIABLES PERSISTENTES
// ══════════════════════════════════════════════════════════════════════════
var float tSl             = na  // SL activo (se mueve con el trailing)
var float tTp             = na  // Take Profit fijo
var float tEnt            = na  // Precio de entrada
var float tRisk           = na  // Riesgo inicial: |entrada - SL_inicial|
var float slInicial       = na
var float slTercio        = na
var float tpTercio        = na
var float distSeguimiento = na
var int   tStep           = 0   // Paso trailing: 0=inicial, 1=BE, 2=50%TP, 3=punto×punto

// ══════════════════════════════════════════════════════════════════════════
// CONDICIONES DE ENTRADA CON PROTECCIÓN CONTRARIA Y ENFRIAMIENTO (COOLDOWN)
// ══════════════════════════════════════════════════════════════════════════
bool inLong  = strategy.position_size > 0
bool inShort = strategy.position_size < 0

// Enfriamiento tras el cierre de una posición
bool posClosed = (strategy.position_size[1] != 0 and strategy.position_size == 0)
var int ultimoCierreBar = -999
if posClosed
    ultimoCierreBar := bar_index

bool cooldownOk = (bar_index - ultimoCierreBar) >= cooldownBars

// Si en el instrumento que se está operando hay una operación contraria abierta, no se debe abrir otra contraria
bool permitLong  = not inShort and strategy.position_size == 0 and cooldownOk
bool permitShort = not inLong and strategy.position_size == 0 and cooldownOk

bool emaLongOk  = close > emaVal
bool emaShortOk = close < emaVal
bool nearEma    = math.abs(close - emaVal) < atrVal * maxDistInp
bool htfLongOk  = not (effIndex and useHtfInp) or htfBull
bool htfShortOk = not (effIndex and useHtfInp) or htfBear

// Alineaciones de condiciones
bool longAligned  = imacdLongOk and adxOk and emaLongOk and nearEma and htfLongOk and shaGreen
bool shortAligned = imacdShortOk and adxOk and emaShortOk and nearEma and htfShortOk and shaRed

// Gatillos: solo se activan cuando las condiciones se alinean por primera vez
bool longTrigger  = longAligned and not longAligned[1]
bool shortTrigger = shortAligned and not shortAligned[1]

bool longC  = permitLong  and longTrigger  and high > high[1]
bool shortC = permitShort and shortTrigger and low  < low[1]

// ══════════════════════════════════════════════════════════════════════════
// SEÑALES DE ENTRADA
// ══════════════════════════════════════════════════════════════════════════
if longC
    tEnt            := close
    slInicial       := calcSL(true, high[1], low[1], atrVal, atrMult)
    tSl             := slInicial
    tTp             := calcTP(tEnt, tSl, minRR)
    tRisk           := math.abs(tEnt - tSl)
    slTercio        := tRisk / 3.0
    tpTercio        := math.abs(tTp - tEnt) / 3.0
    distSeguimiento := na
    tStep           := 0
    strategy.entry("L", strategy.long)
    label.new(bar_index, low,  "▲ COMPRA", color=color.green, textcolor=color.white, style=label.style_label_up,   size=size.small)
    box.new(bar_index, tTp,  bar_index + 10, tEnt, bgcolor=color.new(color.green, 55), border_color=na)
    box.new(bar_index, tEnt, bar_index + 10, tSl,  bgcolor=color.new(color.red,   55), border_color=na)

if shortC
    tEnt            := close
    slInicial       := calcSL(false, high[1], low[1], atrVal, atrMult)
    tSl             := slInicial
    tTp             := calcTP(tEnt, tSl, minRR)
    tRisk           := math.abs(tEnt - tSl)
    slTercio        := tRisk / 3.0
    tpTercio        := math.abs(tTp - tEnt) / 3.0
    distSeguimiento := na
    tStep           := 0
    strategy.entry("S", strategy.short)
    label.new(bar_index, high, "▼ VENTA",  color=color.red,   textcolor=color.white, style=label.style_label_down, size=size.small)
    box.new(bar_index, tEnt, bar_index + 10, tTp,  bgcolor=color.new(color.green, 55), border_color=na)
    box.new(bar_index, tSl,  bar_index + 10, tEnt, bgcolor=color.new(color.red,   55), border_color=na)

// ══════════════════════════════════════════════════════════════════════════
// TRAILING STOP POR TERCIOS (REGLAS.MD)
// ══════════════════════════════════════════════════════════════════════════
bool trailMoved = false

if strategy.position_size != 0 and not na(tRisk) and not na(tTp)
    float tpDist = math.abs(tTp - tEnt)

    if strategy.position_size > 0
        // Actualización LONG
        float viejoSl = tSl
        [nuevoSl, nuevoStep, nuevaDist, nuevoTp] = actualizarSlLong(high, tEnt, slInicial, slTercio, tpTercio, tpDist, tStep, tSl, distSeguimiento, tRisk, beRR, tTp)
        tSl             := nuevoSl
        tStep           := nuevoStep
        distSeguimiento := nuevaDist
        tTp             := nuevoTp
        if tSl != viejoSl
            trailMoved := true

    if strategy.position_size < 0
        // Actualización SHORT
        float viejoSl = tSl
        [nuevoSl, nuevoStep, nuevaDist, nuevoTp] = actualizarSlShort(low, tEnt, slInicial, slTercio, tpTercio, tpDist, tStep, tSl, distSeguimiento, tRisk, beRR, tTp)
        tSl             := nuevoSl
        tStep           := nuevoStep
        distSeguimiento := nuevaDist
        tTp             := nuevoTp
        if tSl != viejoSl
            trailMoved := true

    strategy.exit("Exit", stop=tSl, limit=tTp)

// ══════════════════════════════════════════════════════════════════════════
// INDICADOR DE CALIDAD (bgcolor)
// Verde  → condiciones alineadas alcistas (todo apunta a compra)
// Rojo   → condiciones alineadas bajistas (todo apunta a venta)
// Gris   → sin dirección clara (lateral / sin filtros)
// ══════════════════════════════════════════════════════════════════════════
bool qualBull = adxOk and imacdLongOk  and emaLongOk  and nearEma and shaGreen
bool qualBear = adxOk and imacdShortOk and emaShortOk and nearEma and shaRed
color qualColor = qualBull ? color.new(color.green, 92) : qualBear ? color.new(color.red, 92) : color.new(color.gray, 98)
bgcolor(qualColor, title="Indicador de Calidad")

// ══════════════════════════════════════════════════════════════════════════
// VISUALIZACIÓN
// ══════════════════════════════════════════════════════════════════════════
plotcandle(fO, fC, fC, fO, "SHA",
           color       = fC > fO ? color.new(color.green, 90) : color.new(color.red, 90),
           bordercolor = na)
plot(emaVal, "EMA Adaptativa",  color=color.new(#0a46ea, 35), linewidth=2)
plot(strategy.position_size != 0 ? tSl : na, "Stop Loss activo", color=color.orange, linewidth=2, style=plot.style_linebr)
plot(strategy.position_size != 0 ? tTp : na, "Take Profit",      color=color.lime,   linewidth=1, style=plot.style_linebr, linestyle=plot.linestyle_dashed)

// Señales de entrada
plotshape(longC,  title="Señal LONG",  location=location.belowbar, style=shape.triangleup,   color=color.new(color.green, 0), size=size.small)
plotshape(shortC, title="Señal SHORT", location=location.abovebar, style=shape.triangledown, color=color.new(color.red,   0), size=size.small)

// Señales de trailing (círculo naranja cuando se mueve el SL)
plotshape(trailMoved and strategy.position_size > 0, title="Trail LONG",  location=location.belowbar, style=shape.circle, color=color.orange, size=size.tiny)
plotshape(trailMoved and strategy.position_size < 0, title="Trail SHORT", location=location.abovebar, style=shape.circle, color=color.orange, size=size.tiny)

// ══════════════════════════════════════════════════════════════════════════
// TABLA DE ESTADO
// ══════════════════════════════════════════════════════════════════════════
var table panel = table.new(position.top_right, 2, 7,
                            bgcolor=color.new(color.black, 20),
                            border_width=1, border_color=color.gray)
if barstate.islast
    string dir      = strategy.position_size > 0 ? "🟢 LONG" : strategy.position_size < 0 ? "🔴 SHORT" : "⬜ FLAT"
    string trailTxt = tStep == 0 ? "Esperando" : tStep == 1 ? "BE ✓" : tStep == 2 ? "50% TP ✓" : "Punto×Punto ✓"
    string tipoAct  = effSilver ? "🥈 Plata" : effGold ? "🥇 Oro" : effCrypto ? "₿ Crypto" : effIndex ? "📈 Índice" : effForex ? "💱 Forex" : "Otro"
    string imacdTxt = not useImacd ? "OFF" : imacdSh > 0 ? "▲ Alcista" : imacdSh < 0 ? "▼ Bajista" : "─ Rango"
    color  imacdCol = not useImacd ? color.gray : imacdSh > 0 ? color.green : imacdSh < 0 ? color.red : color.orange

    table.cell(panel, 0, 0, "Sniper + SHA v2", text_color=color.yellow, text_size=size.small)
    table.cell(panel, 1, 0, "Magic:" + str.tostring(magicNum), text_color=color.gray, text_size=size.tiny)
    table.cell(panel, 0, 1, "Activo",   text_color=color.white,  text_size=size.small)
    table.cell(panel, 1, 1, tipoAct,    text_color=color.yellow, text_size=size.small)
    table.cell(panel, 0, 2, "Posición", text_color=color.white,  text_size=size.small)
    table.cell(panel, 1, 2, dir,        text_color=color.white,  text_size=size.small)
    table.cell(panel, 0, 3, "Trailing", text_color=color.white,  text_size=size.small)
    table.cell(panel, 1, 3, trailTxt,   text_color=color.orange, text_size=size.small)
    table.cell(panel, 0, 4, "IMACD",    text_color=color.white,  text_size=size.small)
    table.cell(panel, 1, 4, imacdTxt,   text_color=imacdCol,     text_size=size.small)
    table.cell(panel, 0, 5, "ADX",      text_color=color.white,  text_size=size.small)
    table.cell(panel, 1, 5, str.tostring(math.round(adxVal, 1)) + (adxOk ? " ✓" : " ✗"), text_color=adxOk ? color.green : color.red, text_size=size.small)
    table.cell(panel, 0, 6, "Capital",  text_color=color.white,  text_size=size.small)
    table.cell(panel, 1, 6, "$" + str.tostring(strategy.equity, "#.##"), text_color=color.green, text_size=size.small)
